---
import AppStoreButton from "./AppStoreButton.astro";
---

<section class="bg-shed text-shed-fg">
  <div class="mx-auto max-w-5xl px-4 py-20 text-center sm:px-6 sm:py-28 lg:py-36">
    <h1 class="font-display text-4xl font-bold leading-[1.1] tracking-tight sm:text-5xl lg:text-6xl">
      Sell your stuff,<br />not your Saturday.
    </h1>
    <p class="mx-auto mt-6 max-w-xl text-lg leading-relaxed text-shed-fg/70 sm:text-xl">
      Snap a photo. Get a complete marketplace listing with pricing research, a polished description, and enhanced photos — in minutes.
    </p>
    <div class="mt-10 flex flex-col items-center gap-4 sm:flex-row sm:justify-center">
      <AppStoreButton />
    </div>
    <p class="mt-4 text-sm text-shed-fg/40">
      Free to try. No account required to start.
    </p>
  </div>
</section>
